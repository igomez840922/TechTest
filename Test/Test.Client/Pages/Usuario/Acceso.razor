@*@page "/login"*@
@page "/"

@inject Blazored.LocalStorage.ILocalStorageService _localStorageService;
@inject IUsuarioService _userService;
@inject MudBlazor.ISnackbar _snackBar
@inject NavigationManager _navigatorManager;


<MudCard Elevation="25">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">LOGIN</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudForm Model="@user">
            <MudTextField @bind-Value="user.Email" Label="Email" InputType="InputType.Email" T="string" Required="true" RequiredError="(*) El email es un campo requerido."></MudTextField>
            <MudTextField @bind-Value="user.Password" Label="Password" InputType="InputType.Password" T="string" Required="true" RequiredError="(*) El password es un campo requerido."></MudTextField>
            <br />
            <MudButton Variant="Variant.Filled" Color="Color.Success" @onclick="login">Acceder</MudButton>
        </MudForm>
    </MudCardContent>
</MudCard>
@code {

    MudForm form = new MudForm();
    private Login user = new Login();

    private async void login()
    {
        try
        {
            var data = await _userService.Login(user);
            if (!string.IsNullOrEmpty(data.Token))
            {
                _snackBar.Add($"Bienvenido {user.Email}", Severity.Success);
                await _localStorageService.SetItemAsync("token", data.Token);
                _navigatorManager.NavigateTo("/lista-productos");
            }
            else
            {
                _snackBar.Add($"Debe registrarse para poder acceder", Severity.Success);
                _navigatorManager.NavigateTo("/nuevousuario");
            }
        }
        catch (Exception ex)
        {
            throw new ArgumentException("Se presento un error al loguearse.", ex.Message);
        }
    }
}
