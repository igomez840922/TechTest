@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Details" Class="mr-3 mb-n1" />
            Product Detail
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField Value="@Product?.Id" Label="Product ID" ReadOnly="true" />
        <MudTextField Value="@Product?.Name" Label="Product Name" ReadOnly="true" />
        <MudTextField Value="@Product?.Model" Label="Product Model" ReadOnly="true" />
        <MudTextField Value="@Product?.Price" Label="Product Price" ReadOnly="true" />
        @if (!string.IsNullOrWhiteSpace(Product?.Photo))
        {
            <MudPaper Class="d-flex justify-center py-2 px-1">
                <MudPaper Class="pa-2 mx-2">
                    <img width="150" height="150" src="@(Product.Photo)">
                </MudPaper>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>
