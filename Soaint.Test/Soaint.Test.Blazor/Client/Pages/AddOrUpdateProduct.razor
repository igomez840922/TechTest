@page "/product"
@page "/product/{id:int}"
@using Soaint.Test.Blazor.Client.Services
@using Soaint.Test.Blazor.Shared.Entities
@inject IProductService ProductService
@attribute [Authorize]

@if (Id is null)
{
    <PageTitle>Create new Product</PageTitle>
    <h3>Create new Product</h3>
}
else
{
    <PageTitle>Edit @_product.Name </PageTitle>
    <h3>Edit @_product.Name</h3>
}

<AuthorizeView>
    <Authorized Context="productAuthContext">

        <EditForm Model="_product" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
            <div>
                <label for="name">Nombre</label>
                <InputText id="name" @bind-Value="_product.Name" class="form-control"></InputText>
                <ValidationMessage For="@(() => _product.Name)"/>

            </div>
            <div>
                <label for="description"> Descripcion</label>
                <InputText id="description" @bind-Value="_product.Description" class="form-control"></InputText>
                <ValidationMessage For="@(() => _product.Description)"/>

            </div>
            <div>
                <label for="price">Precio</label>
                <InputNumber id="price" @bind-Value="_product.UnitPrice" class="form-control"></InputNumber>
                <ValidationMessage For="@(() => _product.UnitPrice)"/>

            </div>
            <div>
                <label>Model</label>
                <br/>
                <InputSelect @bind-Value="_product.ModelId" class="form-select">
                    @foreach (var listModel in ProductService.Models)
                    {
                        <option value=@listModel.Id> @listModel.Description</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => _product.ModelId)"/>
            </div>
            <br/>
            <button type="submit" class="btn btn-primary">@btnText</button>
            <button type="submit" class="btn btn-danger" @onclick="DeleteProduct">Delete Product</button>

        </EditForm>
    </Authorized>
    <NotAuthorized>
        <span> No se encuentra autorizado</span>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public int? Id { get; set; }

    string btnText = string.Empty;
    Product _product = new Product { Model = new Model() };

    protected override async Task OnInitializedAsync()
    {
        btnText = Id is null ? "Add new product" : "update product";
        await ProductService.GetModels();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id is null)
        {
            _product.Model = ProductService.Models[0];
            _product.ModelId = _product.Model.Id;
        }
        else
        {
            _product = await ProductService.Get((int)Id);
        }
    }

    async Task HandleSubmit()
    {
        if (Id is null)
        {
            await ProductService.Create(_product);
        }
        else
            await ProductService.Update(_product);
    }

    async Task DeleteProduct()
    {
        await ProductService.Delete(_product.Id);
    }
}